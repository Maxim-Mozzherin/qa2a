func (r *Repository) GetCompanyMembers(companyID int) ([]struct {
	UserID   int    `db:"id"`
	FullName string `db:"full_name"`
	Role     string `db:"role"`
}, error) {
	var members []struct {
		UserID   int    `db:"id"`
		FullName string `db:"full_name"`
		Role     string `db:"role"`
	}
	query := `SELECT u.id, u.full_name, m.role FROM users u 
              JOIN memberships m ON u.id = m.user_id 
              WHERE m.company_id = $1`
	err := r.db.Select(&members, query, companyID)
	return members, err
}