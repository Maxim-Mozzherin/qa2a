const tg = window.Telegram?.WebApp || {};
const API = window.location.origin + '/api';
let userToken, currentCompanyId, catalog = [], locations = [];

tg.ready(); tg.expand();
document.addEventListener('DOMContentLoaded', initApp);

async function initApp() {
    localStorage.clear(); // ПРИНУДИТЕЛЬНЫЙ СБРОС СТАРЫХ ГЛЮКОВ
    try {
        const res = await fetch(API + '/auth', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tg.initData ? { initData: tg.initData } : { demo_id: 999, demo_name: "Boss" })
        });
        const data = await res.json();
        userToken = data.user.tg_id;
        
        if (!data.memberships || data.memberships.length === 0) {
            document.getElementById('onboarding').style.display = 'block';
            document.getElementById('main-app').style.display = 'none';
        } else {
            currentCompanyId = data.memberships[0].company_id;
            document.getElementById('main-app').style.display = 'block';
            document.getElementById('onboarding').style.display = 'none';
            document.getElementById('orgName').textContent = data.memberships[0].company_name;
            
            await refreshData();
            loadHistory();
            renderCompanyList(data.memberships);
        }
    } catch (e) { alert("Ошибка входа"); }
}

function getHeaders() { return { 'Content-Type': 'application/json', 'X-Telegram-ID': String(userToken), 'X-Company-ID': String(currentCompanyId) }; }

async function refreshData() {
    const [resP, resL] = await Promise.all([
        fetch(API + '/positions', { headers: getHeaders() }),
        fetch(API + '/locations', { headers: getHeaders() })
    ]);
    catalog = await resP.json() || [];
    locations = await resL.json() || [];
    const opts = '<option value="">Выбрать склад...</option>' + locations.map(l => `<option value="${l.id}">${l.name}</option>`).join('');
    ['w_location', 'p_location'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).innerHTML = opts; });
}

function filterSearch(prefix) {
    const q = document.getElementById(prefix + '_search').value.toLowerCase();
    const div = document.getElementById(prefix + '_results');
    const matches = catalog.filter(p => p.name.toLowerCase().includes(q));
    div.innerHTML = matches.map(p => `<div class="search-item" onclick="selectPos('${prefix}','${p.name}','${p.unit}')">${p.name}</div>`).join('');
    div.style.display = (q && matches.length > 0) ? 'block' : 'none';
}

function selectPos(prefix, name, unit) {
    document.getElementById(prefix + '_name').value = name;
    document.getElementById(prefix + '_search').value = name;
    document.getElementById(prefix + '_results').style.display = 'none';
    document.getElementById(prefix + '_unit_display').textContent = unit;
}

async function submitOperation(type, prefix) {
    const name = document.getElementById(prefix + '_name').value;
    const qty = document.getElementById(prefix + '_qty').value;
    const loc = document.getElementById(prefix + '_location').value;
    if(!name || !qty || !loc) return alert("Заполни всё!");
    await fetch(API + '/operations', { method: 'POST', headers: getHeaders(), body: JSON.stringify({ position_name: name, quantity: parseFloat(qty), type, location_id: parseInt(loc) }) });
    closeDrawer(); loadHistory();
}

async function submitNewPosition() {
    const name = document.getElementById('p_name').value;
    const unit = document.getElementById('p_unit').value;
    const qty = document.getElementById('p_init_qty').value;
    const loc = document.getElementById('p_location').value;
    if(!name || !loc) return alert("Имя и склад!");
    await fetch(API + '/positions', { method: 'POST', headers: getHeaders(), body: JSON.stringify({ name, unit, initial_quantity: parseFloat(qty)||0, location_id: parseInt(loc) }) });
    closeDrawer(); await refreshData();
}

async function submitNewLocation() {
    const name = document.getElementById('loc_name').value;
    if(name) { await fetch(API + '/locations', { method: 'POST', headers: getHeaders(), body: JSON.stringify({ name }) }); closeDrawer(); await refreshData(); }
}

function switchTab(id) {
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    document.getElementById('tab-' + id).style.display = 'block';
    if(id === 'stock') loadStock();
}

async function loadStock() {
    const res = await fetch(API + '/balances', { headers: getHeaders() });
    const data = await res.json() || [];
    document.getElementById('stockList').innerHTML = data.map(b => `<div class="pulse-item"><div>${b.position_name}</div><div>${b.quantity} ${b.unit}</div></div>`).join('') || "Пусто";
}

async function loadHistory() {
    const res = await fetch(API + '/operations', { headers: getHeaders() });
    const data = await res.json() || [];
    document.getElementById('historyFeed').innerHTML = data.map(op => `<div class="pulse-item"><div>${op.position_name}</div><div style="color:red">${op.quantity}</div></div>`).join('');
}

function renderCompanyList(m) {
    document.getElementById('companyList').innerHTML = m.map(i => `<div class="pulse-item" onclick="localStorage.setItem('selected_company_id',${i.company_id});location.reload()">${i.company_name}</div>`).join('');
}

function openDrawer(id) { document.getElementById('overlay').style.display='block'; document.getElementById('drawer_'+id).classList.add('open'); }
function closeDrawer() { document.querySelectorAll('.drawer').forEach(d=>d.classList.remove('open')); document.getElementById('overlay').style.display='none'; }

window.openDrawer = openDrawer; window.closeDrawer = closeDrawer; window.switchTab = switchTab;
window.submitOperation = submitOperation; window.submitNewPosition = submitNewPosition; window.submitNewLocation = submitNewLocation;
window.filterSearch = filterSearch; window.selectPos = selectPos;
window.createNewBusiness = async () => { 
    const n = prompt("Название:"); 
    if(n) { 
        const res = await fetch(API + '/companies', { method: 'POST', headers: getHeaders(), body: JSON.stringify({ name: n }) }); 
        const d = await res.json(); 
        localStorage.setItem('selected_company_id', d.id); 
        location.reload(); 
    } 
};
window.joinByCode = async () => { const c = prompt("Код:"); if(c) { await fetch(API + '/join', { method: 'POST', headers: getHeaders(), body: JSON.stringify({ code: c }) }); location.reload(); } };
window.showInviteCode = async () => { const res = await fetch(API + '/invite-code', { headers: getHeaders() }); const d = await res.json(); alert("Код: " + d.code); };
async function submitCreateBusiness() {
    const name = document.getElementById('new_biz_name').value;
    if(!name) return;
    const res = await fetch(API + '/companies', {
        method: 'POST', headers: getHeaders(),
        body: JSON.stringify({ name: name })
    });
    if(res.ok) {
        const d = await res.json();
        localStorage.setItem('selected_company_id', d.id);
        location.reload();
    }
}

async function joinByCode() {
    const code = prompt("Введите код заведения (QA-XXXX):");
    if(!code) return;
    const res = await fetch(API + '/join', {
        method: 'POST', headers: getHeaders(),
        body: JSON.stringify({ code: code.toUpperCase() })
    });
    if(res.ok) {
        alert("Вы успешно добавлены!");
        location.reload();
    } else {
        alert("Код не найден или вы уже в команде");
    }
}

async function loadTeamData() {
    // 1. Грузим список людей
    const resM = await fetch(API + '/members', { headers: getHeaders() });
    const members = await resM.json();
    document.getElementById('memberList').innerHTML = members.map(m => `
        <div class="pulse-item">
            <div>${m.full_name}</div>
            <span class="pulse-val" style="font-size:11px; color:var(--accent)">${m.role.toUpperCase()}</span>
        </div>
    `).join('');

    // 2. Грузим инвайт-код
    const resC = await fetch(API + '/invite-code', { headers: getHeaders() });
    const dataC = await resC.json();
    document.getElementById('displayInviteCode').textContent = dataC.code;
}

// В switchTab добавь вызов
if(id === 'team') loadTeamData();
